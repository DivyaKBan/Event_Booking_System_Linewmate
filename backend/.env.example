# Server
PORT=5000
NODE_ENV=development

# Database
# Local MongoDB example: mongodb://127.0.0.1:27017/event-booking
# MongoDB Atlas example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/event-booking
MONGO_URI=mongodb://127.0.0.1:27017/event-booking

# Auth
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS - the URL of the deployed/running frontend
CLIENT_URL=http://localhost:5173
